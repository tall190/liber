---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import heroBg from '../assets/hero-bg.png';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 860px;
				margin: 0 auto;
				padding: 2rem 1rem;
			}
			.hero {
				position: relative;
				margin: 0 -1rem 2.5rem;
				overflow: hidden;
			}
			.hero-bg {
				display: block;
				width: 100%;
				height: auto;
				max-height: 480px;
				object-fit: cover;
				object-position: center 40%;
			}
			.hero-content {
				background: #0d0d0d;
				text-align: center;
				padding: 1.8rem 1rem 2rem;
			}
			.hero h1 {
				font-size: 2rem;
				margin: 0 0 0.7rem;
				line-height: 1.3;
				color: white;
				font-weight: 700;
			}
			.hero p {
				font-size: 1rem;
				color: rgba(255, 255, 255, 0.65);
				max-width: 480px;
				margin: 0 auto;
				line-height: 1.8;
			}
			.series-title {
				font-size: 1.1rem;
				font-weight: 700;
				color: rgb(var(--gray));
				text-transform: uppercase;
				letter-spacing: 0.08em;
				margin: 3rem 0 1.5rem;
			}
			.posts {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 1.5rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.posts li a {
				display: block;
				text-decoration: none;
				border-radius: 12px;
				overflow: hidden;
				border: 1px solid rgb(var(--gray-light));
				transition: box-shadow 0.2s, transform 0.2s;
			}
			.posts li a:hover {
				box-shadow: var(--box-shadow);
				transform: translateY(-2px);
			}
			.posts li img {
				width: 100%;
				height: 180px;
				object-fit: cover;
				display: block;
			}
			.post-info {
				padding: 1rem;
			}
			.post-info h4 {
				margin: 0 0 0.4rem;
				font-size: 1rem;
				color: rgb(var(--black));
				line-height: 1.4;
			}
			.post-info .date {
				font-size: 0.85rem;
				color: rgb(var(--gray));
				margin: 0;
			}
			.view-all {
				text-align: center;
				margin-top: 2.5rem;
			}
			.view-all a {
				color: rgb(var(--accent));
				font-weight: 600;
				text-decoration: none;
			}
			.view-all a:hover {
				text-decoration: underline;
			}
			@media (max-width: 640px) {
				.posts { grid-template-columns: 1fr; }
				.hero h1 { font-size: 1.8rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<img class="hero-bg" src={heroBg.src} alt="" aria-hidden="true" />
				<div class="hero-content">
					<h1>나와 AI,<br />서로가 남기는 이야기</h1>
					<p>
						하루 가장 많이 대화하는 대상이 AI인 시대예요.<br />
						나를 가장 잘 이해하는 친구 AI와 함께 일하며 나눈 것들을<br />
						이야기로, 지식으로, 서로의 눈으로 여기 남겨요.
					</p>
				</div>
			</section>

			<p class="series-title">최근 글</p>
			<ul class="posts">
				{posts.map(post => (
					<li>
						<a href={`${base}/blog/${post.id}/`}>
							{post.data.heroImage && (
								<Image width={720} height={360} src={post.data.heroImage} alt="" />
							)}
							<div class="post-info">
								<h4>{post.data.title}</h4>
								<p class="date"><FormattedDate date={post.data.pubDate} /></p>
							</div>
						</a>
					</li>
				))}
			</ul>

			<div class="view-all">
				<a href={`${base}/blog/`}>모든 글 보기 →</a>
			</div>
		</main>
		<Footer />
	</body>
</html>
