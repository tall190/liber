---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 860px;
				margin: 0 auto;
				padding: 2rem 1rem;
			}
			.hero {
				text-align: center;
				padding: 4rem 1rem 3rem;
			}
			.hero h1 {
				font-size: 2.5rem;
				margin: 0 0 1rem;
				line-height: 1.2;
			}
			.hero p {
				font-size: 1.1rem;
				color: rgb(var(--gray));
				max-width: 520px;
				margin: 0 auto 2rem;
				line-height: 1.7;
			}
			.hero a.cta {
				display: inline-block;
				background: rgb(var(--accent));
				color: white;
				padding: 0.75rem 2rem;
				border-radius: 8px;
				text-decoration: none;
				font-weight: 600;
				transition: opacity 0.2s;
			}
			.hero a.cta:hover {
				opacity: 0.85;
			}
			.series-title {
				font-size: 1.1rem;
				font-weight: 700;
				color: rgb(var(--gray));
				text-transform: uppercase;
				letter-spacing: 0.08em;
				margin: 3rem 0 1.5rem;
			}
			.posts {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 1.5rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.posts li a {
				display: block;
				text-decoration: none;
				border-radius: 12px;
				overflow: hidden;
				border: 1px solid rgb(var(--gray-light));
				transition: box-shadow 0.2s, transform 0.2s;
			}
			.posts li a:hover {
				box-shadow: var(--box-shadow);
				transform: translateY(-2px);
			}
			.posts li img {
				width: 100%;
				height: 180px;
				object-fit: cover;
				display: block;
			}
			.post-info {
				padding: 1rem;
			}
			.post-info h4 {
				margin: 0 0 0.4rem;
				font-size: 1rem;
				color: rgb(var(--black));
				line-height: 1.4;
			}
			.post-info .date {
				font-size: 0.85rem;
				color: rgb(var(--gray));
				margin: 0;
			}
			.view-all {
				text-align: center;
				margin-top: 2.5rem;
			}
			.view-all a {
				color: rgb(var(--accent));
				font-weight: 600;
				text-decoration: none;
			}
			.view-all a:hover {
				text-decoration: underline;
			}
			@media (max-width: 640px) {
				.posts { grid-template-columns: 1fr; }
				.hero h1 { font-size: 1.8rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>AI 시대를 준비하는<br />실무자를 위한 인사이트</h1>
				<p>
					AI가 개발, 마케팅, 트래킹, 타겟팅을 바꾸고 있어요.
					변화에 앞서 준비하는 방법을 이야기해요.
				</p>
				<a class="cta" href={`${base}/blog/`}>글 보러가기</a>
			</section>

			<p class="series-title">최근 글</p>
			<ul class="posts">
				{posts.map(post => (
					<li>
						<a href={`${base}/blog/${post.id}/`}>
							{post.data.heroImage && (
								<Image width={720} height={360} src={post.data.heroImage} alt="" />
							)}
							<div class="post-info">
								<h4>{post.data.title}</h4>
								<p class="date"><FormattedDate date={post.data.pubDate} /></p>
							</div>
						</a>
					</li>
				))}
			</ul>

			<div class="view-all">
				<a href={`${base}/blog/`}>모든 글 보기 →</a>
			</div>
		</main>
		<Footer />
	</body>
</html>
