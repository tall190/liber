			{ cat:"AI 이해", text:"AI 업계 트렌드를 어떻게 파악하나요?", opts:[{t:"신경 쓰지 않는다",s:1},{t:"뉴스 보면서 파악한다",s:2},{t:"정기적으로 학습하고 활용에 반영한다",s:3}] },
			{ cat:"AI 이해", text:"AI 윤리 이슈를 어떻게 다루나요?", opts:[{t:"생각해본 적 없다",s:1},{t:"문제가 생기면 피한다",s:2},{t:"사전에 가이드라인을 만들어 적용한다",s:3}] },
			{ cat:"AI 이해", text:"AI를 통해 무엇을 달성하고 싶은지 명확한가요?", opts:[{t:"특별히 없다",s:1},{t:"업무 효율화 정도",s:2},{t:"구체적인 목표와 실행 계획이 있다",s:3}] },
			{ cat:"AI 이해", text:"AI 시대에 내가 해야 할 역할을 정의해봤나요?", opts:[{t:"생각해본 적 없다",s:1},{t:"대략 그려봤다",s:2},{t:"명확히 정의했고 그에 맞게 역량을 키우고 있다",s:3}] },
			// ── AI 사실 확인 ──────────────────────────────────────
			{ cat:"AI 사실 확인", type:"fact", text:"AI의 토큰 사용량은 내가 입력한 질문 텍스트의 크기로만 결정된다.", answer:false, explanation:"토큰은 입력 질문뿐 아니라 시스템 프롬프트, 첨부 파일, AI의 응답까지 모두 포함해요. 긴 답변을 요청할수록 응답 토큰도 많이 써요." },
			{ cat:"AI 사실 확인", type:"fact", text:"같은 프롬프트를 반복하면 항상 동일한 답이 나온다.", answer:false, explanation:"AI는 확률적으로 작동해요. temperature 설정에 따라 같은 입력이라도 매번 다른 결과가 나올 수 있어요." },
			{ cat:"AI 사실 확인", type:"fact", text:"AI 모델은 학습 데이터 이후에 일어난 사건은 기본적으로 알 수 없다.", answer:true, explanation:"맞아요. AI 모델엔 '학습 컷오프'가 있어요. 그 이후 사건은 실시간 검색 기능이 없으면 알 수 없어요." },
			{ cat:"AI 사실 확인", type:"fact", text:"프롬프트가 길수록 항상 더 좋은 결과가 나온다.", answer:false, explanation:"관련 없는 정보가 많으면 AI가 핵심을 놓쳐요. 간결하고 핵심에 집중된 정보가 더 중요해요." },
			{ cat:"AI 사실 확인", type:"fact", text:"'단계별로 생각해줘'라고 하면 복잡한 문제에서 AI 정확도가 높아진다.", answer:true, explanation:"맞아요. 중간 추론 단계를 거치게 하는 Chain-of-Thought 방식은 최종 답의 정확도를 높여주는 게 연구로 증명됐어요." },
			{ cat:"AI 사실 확인", type:"fact", text:"AI가 자신 있게 말하는 내용은 사실이다.", answer:false, explanation:"AI는 틀린 답을 매우 확신 있게 말하기도 해요. 이걸 '할루시네이션'이라고 해요. 중요한 내용은 반드시 검증이 필요해요." },
			{ cat:"AI 사실 확인", type:"fact", text:"GPT, Claude, Gemini는 모두 동일한 방식으로 학습됐다.", answer:false, explanation:"각 모델은 학습 데이터, 구조, 훈련 방법이 달라요. 그래서 같은 질문에도 각기 다른 강점을 보여요." },
			{ cat:"AI 사실 확인", type:"fact", text:"기본 AI는 인터넷에 실시간으로 접속해 최신 정보를 가져온다.", answer:false, explanation:"기본 AI는 학습 데이터 기반으로 작동해요. 실시간 검색은 별도 기능으로 탑재된 경우에만 가능해요." },
			{ cat:"AI 사실 확인", type:"fact", text:"AI 모델은 클수록 모든 작업에서 더 좋은 결과를 낸다.", answer:false, explanation:"단순 반복 작업에는 소형 모델이 더 빠르고 경제적이에요. 작업의 성격에 맞는 모델을 선택하는 게 중요해요." },
			{ cat:"AI 사실 확인", type:"fact", text:"AI 대화가 끝나면 기본적으로 내용을 기억하지 못한다.", answer:true, explanation:"맞아요. AI는 기본적으로 세션이 끝나면 대화 내용을 잊어요. memory 파일이나 컨텍스트 파일로 별도 관리해야 해요." },
			{ cat:"AI 사실 확인", type:"fact", text:"시스템 프롬프트(내부 지시)는 어떤 방법으로도 사용자에게 노출되지 않는다.", answer:false, explanation:"프롬프트 인젝션 같은 공격으로 시스템 프롬프트가 노출된 사례가 있어요. 완전한 보안은 보장되지 않아요." },
			{ cat:"AI 사실 확인", type:"fact", text:"AI에게 예시를 먼저 보여주면 원하는 포맷의 결과를 얻기 더 쉽다.", answer:true, explanation:"맞아요. 원하는 형식의 예시를 먼저 보여주는 few-shot 방식은 AI가 의도를 정확히 파악하게 해서 결과 품질이 높아져요." },
		];

		const LEVELS = [
			{ min:20, max:30, emoji:"🌱", title:"입문자", range:"20~30점", desc:"이제 막 시작한 거예요. AI가 무엇을 할 수 있는지 탐색하는 단계예요. 다음 단계로 가려면 — 결과보다 문제를 먼저 말하는 연습을 해보세요." },
			{ min:31, max:41, emoji:"⚡", title:"사용자", range:"31~41점", desc:"기본은 갖춘 단계예요. AI와 대화하는 방식을 알고 있어요. 다음 단계로 가려면 — 반복되는 작업을 구조화해보세요." },
			{ min:42, max:52, emoji:"🔧", title:"설계자", range:"42~52점", desc:"도구를 만드는 사람이에요. AI를 쓰는 게 아니라 AI가 작동하는 방식을 설계하고 있어요. 상위 15% 안에 있어요." },
			{ min:53, max:60, emoji:"🛡️", title:"어벤져스", range:"53~60점", desc:"AI 조직을 운영하고 있어요. 당신이 없어도 시스템이 돌아가고, 당신은 방향을 잡는 역할을 하고 있어요. 닉 퓨리 레벨이에요." },
		];

		let selected = [];
		let currentQ = 0;
		let scores = [];
		let selectedScore = null;

		function shuffle(arr) {
			const a = [...arr];
			for (let i = a.length - 1; i > 0; i--) {
				const j = Math.floor(Math.random() * (i + 1));
				[a[i], a[j]] = [a[j], a[i]];
			}
			return a;
		}

		function init() {
			selected = shuffle(ALL_QUESTIONS).slice(0, 20);
			currentQ = 0;
			scores = [];
			selectedScore = null;
		}

		function getLevel(total) {
			return LEVELS.find(l => total >= l.min && total <= l.max) || LEVELS[0];
		}

		function render() {
			const q = selected[currentQ];
			document.getElementById('qcat').textContent = q.cat;
			document.getElementById('qtext').textContent = q.text;
			document.getElementById('progress-text').textContent = `${currentQ + 1} / 20`;
			document.getElementById('progress-bar').style.width = `${((currentQ + 1) / 20) * 100}%`;
			document.getElementById('next-btn').textContent = currentQ === 19 ? '결과 보기 →' : '다음 →';
			document.getElementById('next-btn').disabled = true;
			document.getElementById('fact-feedback').className = 'fact-feedback hidden';
			selectedScore = null;

			const opts = document.getElementById('options');
			opts.innerHTML = '';

			if (q.type === 'fact') {
				['맞다', '틀리다'].forEach((label, i) => {
					const btn = document.createElement('button');
					btn.className = 'option';
					btn.innerHTML = `<span class="option-badge">${i === 0 ? 'O' : 'X'}</span><span>${label}</span>`;
					btn.addEventListener('click', () => {
						if (selectedScore !== null) return;
						const userSaysTrue = (i === 0);
						const isCorrect = userSaysTrue === q.answer;
						selectedScore = isCorrect ? 3 : 1;

						document.querySelectorAll('.option').forEach((b, bi) => {
							const bSaysTrue = (bi === 0);
							if (bSaysTrue === q.answer) b.classList.add('correct-ans');
							else if (b === btn) b.classList.add('wrong-ans');
							b.style.pointerEvents = 'none';
						});

						const fb = document.getElementById('fact-feedback');
						fb.className = 'fact-feedback ' + (isCorrect ? 'correct' : 'wrong');
						fb.innerHTML = `<div class="fb-title">${isCorrect ? '✓ 정답이에요!' : '✗ 틀렸어요'}</div>${q.explanation}`;
						document.getElementById('next-btn').disabled = false;
					});
					opts.appendChild(btn);
				});
			} else {
				q.opts.forEach((opt, i) => {
					const btn = document.createElement('button');
					btn.className = 'option';
					btn.innerHTML = `<span class="option-badge">${String.fromCharCode(65+i)}</span><span>${opt.t}</span>`;
					btn.addEventListener('click', () => {
						document.querySelectorAll('.option').forEach(b => b.classList.remove('selected'));
						btn.classList.add('selected');
						selectedScore = opt.s;
						document.getElementById('next-btn').disabled = false;
					});
					opts.appendChild(btn);
				});
			}
		}

		function showResult() {
			document.getElementById('quiz-screen').classList.add('hidden');
			document.getElementById('result-screen').classList.remove('hidden');

			const total = scores.reduce((a,b)=>a+b, 0);
			const lv = getLevel(total);

			document.getElementById('remoji').textContent = lv.emoji;
			document.getElementById('rscore').textContent = `총점 ${total}점 / 60점`;
			document.getElementById('rtitle').textContent = lv.title;
			document.getElementById('rdesc').textContent = lv.desc;

			const lmap = document.getElementById('level-map');
			lmap.innerHTML = '';
			LEVELS.forEach(l => {
				const c = document.createElement('div');
				c.className = 'level-card' + (l.title === lv.title ? ' current' : '');
				c.innerHTML = `<span class="le">${l.emoji}</span>${l.title}<div class="lr">${l.range}</div>`;
				lmap.appendChild(c);
			});

			const bl = document.getElementById('breakdown-list');
			bl.innerHTML = '';
			selected.forEach((q, i) => {
				const item = document.createElement('div');
				item.className = 'bi';
				item.innerHTML = `<span>${q.cat} — ${q.text.slice(0,24)}…</span><span class="bs">${scores[i]}점</span>`;
				bl.appendChild(item);
			});
		}

		document.getElementById('next-btn').addEventListener('click', () => {
			if (selectedScore === null) return;
			scores.push(selectedScore);
			currentQ++;
			if (currentQ >= 20) showResult();
			else render();
		});

		document.getElementById('restart-btn').addEventListener('click', () => {
			document.getElementById('result-screen').classList.add('hidden');
			document.getElementById('quiz-screen').classList.remove('hidden');
			init();
			render();
		});

		init();
		render();
		</script>
	</body>
</html>
