---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title="AI 활용 수준 자가진단 — Liber" description="나는 AI를 얼마나 잘 쓰고 있을까? 100개 문제 중 20개 랜덤 퀴즈로 알아보는 AI 활용 수준 테스트." />
		<style>
			main { max-width: 720px; margin: 0 auto; padding: 3rem 1rem; }
			.quiz-header { text-align: center; margin-bottom: 2.5rem; }
			.quiz-header h1 { font-size: 1.8rem; margin-bottom: 0.4rem; }
			.quiz-header p { color: rgb(var(--gray)); font-size: 0.95rem; }
			.badge { display: inline-block; background: rgba(var(--accent),0.1); color: rgb(var(--accent)); font-size: 0.75rem; font-weight: 600; padding: 0.2rem 0.6rem; border-radius: 999px; margin-bottom: 0.5rem; }
			.progress-text { text-align: right; font-size: 0.85rem; color: rgb(var(--gray)); margin-bottom: 0.4rem; }
			.progress-bar-wrap { background: rgb(var(--gray-light)); border-radius: 999px; height: 5px; margin-bottom: 1.5rem; overflow: hidden; }
			.progress-bar { background: rgb(var(--accent)); height: 100%; border-radius: 999px; transition: width 0.3s ease; }
			.question-card { background: white; border: 1px solid rgb(var(--gray-light)); border-radius: 12px; padding: 2rem; margin-bottom: 1rem; }
			.question-category { font-size: 0.75rem; font-weight: 600; color: rgb(var(--accent)); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.6rem; }
			.question-text { font-size: 1.05rem; font-weight: 600; line-height: 1.6; margin-bottom: 1.5rem; color: rgb(var(--gray-dark)); }
			.options { display: flex; flex-direction: column; gap: 0.65rem; }
			.option { display: flex; align-items: flex-start; gap: 0.75rem; padding: 0.9rem 1.1rem; border: 1.5px solid rgb(var(--gray-light)); border-radius: 8px; cursor: pointer; transition: all 0.15s; text-align: left; background: white; width: 100%; font-size: 0.92rem; line-height: 1.5; color: rgb(var(--gray-dark)); }
			.option:hover { border-color: rgb(var(--accent)); background: rgba(var(--accent),0.03); }
			.option.selected { border-color: rgb(var(--accent)); background: rgba(var(--accent),0.06); font-weight: 500; }
			.option-badge { flex-shrink: 0; width: 22px; height: 22px; border-radius: 50%; background: rgb(var(--gray-light)); display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 700; color: rgb(var(--gray)); margin-top: 2px; }
			.option.selected .option-badge { background: rgb(var(--accent)); color: white; }
			.nav-buttons { display: flex; justify-content: flex-end; margin-top: 1rem; }
			.btn-primary { padding: 0.65rem 1.4rem; border-radius: 8px; border: none; cursor: pointer; font-size: 0.9rem; font-weight: 600; background: rgb(var(--accent)); color: white; transition: opacity 0.15s; }
			.btn-primary:hover { opacity: 0.9; }
			.btn-primary:disabled { opacity: 0.35; cursor: not-allowed; }

			/* 결과 */
			.result-screen { text-align: center; }
			.result-emoji { font-size: 3.5rem; margin-bottom: 0.5rem; }
			.result-score-text { font-size: 1rem; color: rgb(var(--gray)); margin-bottom: 0.3rem; }
			.result-title { font-size: 2rem; font-weight: 700; margin-bottom: 0.75rem; color: rgb(var(--gray-dark)); }
			.result-desc { font-size: 0.97rem; line-height: 1.8; color: rgb(var(--gray)); max-width: 480px; margin: 0 auto 2rem; }
			.level-map { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.6rem; margin-bottom: 2rem; }
			.level-card { border: 1.5px solid rgb(var(--gray-light)); border-radius: 8px; padding: 0.7rem 0.5rem; font-size: 0.78rem; text-align: center; color: rgb(var(--gray)); }
			.level-card.current { border-color: rgb(var(--accent)); background: rgba(var(--accent),0.05); color: rgb(var(--gray-dark)); font-weight: 600; }
			.level-card .le { font-size: 1.4rem; display: block; margin-bottom: 0.2rem; }
			.level-card .lr { font-size: 0.68rem; color: rgb(var(--gray)); margin-top: 0.15rem; }
			.breakdown { background: rgb(var(--gray-light)); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 2rem; text-align: left; }
			.breakdown h3 { font-size: 0.82rem; font-weight: 600; color: rgb(var(--gray)); margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; }
			.bi { display: flex; justify-content: space-between; align-items: center; padding: 0.4rem 0; border-bottom: 1px solid rgba(var(--gray),0.15); font-size: 0.85rem; color: rgb(var(--gray-dark)); }
			.bi:last-child { border-bottom: none; }
			.bs { font-weight: 700; color: rgb(var(--accent)); }
			.restart-btn { background: transparent; border: 1.5px solid rgb(var(--gray-light)); color: rgb(var(--gray)); padding: 0.55rem 1.1rem; border-radius: 8px; cursor: pointer; font-size: 0.88rem; transition: all 0.15s; }
			.restart-btn:hover { border-color: rgb(var(--gray)); }
			.hidden { display: none; }

			/* 사실 확인 문제 */
			.fact-tag { display: inline-block; font-size: 0.72rem; font-weight: 700; padding: 0.15rem 0.5rem; border-radius: 4px; background: rgba(var(--accent),0.12); color: rgb(var(--accent)); margin-bottom: 0.5rem; letter-spacing: 0.04em; }
			.option.correct-ans { border-color: #22c55e !important; background: rgba(34,197,94,0.07) !important; }
			.option.wrong-ans { border-color: #ef4444 !important; background: rgba(239,68,68,0.06) !important; opacity: 0.75; }
			.fact-feedback { margin-top: 1rem; padding: 0.85rem 1.1rem; border-radius: 8px; border: 1.5px solid; font-size: 0.9rem; line-height: 1.65; }
			.fact-feedback.correct { background: rgba(34,197,94,0.06); border-color: rgba(34,197,94,0.45); color: #15803d; }
			.fact-feedback.wrong { background: rgba(239,68,68,0.05); border-color: rgba(239,68,68,0.35); color: #b91c1c; }
			.fact-feedback .fb-title { font-weight: 700; margin-bottom: 0.3rem; font-size: 0.95rem; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="quiz-header">
				<div class="badge">100개 중 20개 랜덤</div>
				<h1>AI 활용 수준 자가진단</h1>
				<p>실전 질문 20개로 알아보는 나의 AI 활용 레벨</p>
			</div>

			<div id="quiz-screen">
				<p class="progress-text" id="progress-text">1 / 20</p>
				<div class="progress-bar-wrap"><div class="progress-bar" id="progress-bar" style="width:5%"></div></div>
				<div class="question-card" id="question-card">
					<div class="question-category" id="qcat"></div>
					<div class="question-text" id="qtext"></div>
					<div class="options" id="options"></div>
				<div id="fact-feedback" class="fact-feedback hidden"></div>
				</div>
				<div class="nav-buttons">
					<button class="btn-primary" id="next-btn" disabled>다음 →</button>
				</div>
			</div>

			<div id="result-screen" class="result-screen hidden">
				<div class="result-emoji" id="remoji"></div>
				<div class="result-score-text" id="rscore"></div>
				<div class="result-title" id="rtitle"></div>
				<div class="result-desc" id="rdesc"></div>
				<div class="level-map" id="level-map"></div>
				<div class="breakdown">
					<h3>질문별 점수</h3>
					<div id="breakdown-list"></div>
				</div>
				<button class="restart-btn" id="restart-btn">다시 하기 (새 문제)</button>
			</div>
		</main>
		<Footer />

		<script>
		const ALL_QUESTIONS = [
			// ── 요청의 기술 ──────────────────────────────────────
			{ cat:"요청의 기술", text:"AI에게 처음 요청할 때 어떻게 시작하나요?", opts:[{t:"바로 원하는 결과를 말한다",s:1},{t:"배경을 간략히 설명하고 시작한다",s:2},{t:"문제 상황을 먼저 설명하고 원하는 방향을 제시한다",s:3}] },
			{ cat:"요청의 기술", text:"복잡한 작업을 시킬 때 어떻게 하나요?", opts:[{t:"한 번에 전부 말한다",s:1},{t:"단계별로 나눠서 시킨다",s:2},{t:"먼저 계획을 세우게 하고 승인 후 진행시킨다",s:3}] },
			{ cat:"요청의 기술", text:"글쓰기를 부탁할 때 어떻게 시키나요?", opts:[{t:"'글 써줘'라고 한다",s:1},{t:"주제, 분량, 톤을 설명한다",s:2},{t:"독자, 목적, 구조까지 정의하고 시작한다",s:3}] },
			{ cat:"요청의 기술", text:"AI에게 역할을 부여해본 적 있나요?", opts:[{t:"없다. 그냥 AI로 쓴다",s:1},{t:"'마케터처럼 써줘' 정도로 써봤다",s:2},{t:"구체적인 페르소나와 제약조건을 설정하고 쓴다",s:3}] },
			{ cat:"요청의 기술", text:"AI 답변이 너무 길거나 짧을 때?", opts:[{t:"그냥 쓴다",s:1},{t:"'더 짧게/길게'라고 한다",s:2},{t:"처음부터 분량 조건을 명시한다",s:3}] },
			{ cat:"요청의 기술", text:"AI에게 예시를 제공한 적 있나요?", opts:[{t:"없다. 설명만 한다",s:1},{t:"비슷한 예시를 가끔 보여준다",s:2},{t:"원하는 포맷의 예시를 항상 먼저 보여준다",s:3}] },
			{ cat:"요청의 기술", text:"같은 질문을 여러 방식으로 물어본 적 있나요?", opts:[{t:"없다. 한 번만 묻는다",s:1},{t:"결과가 나쁘면 다시 물어본다",s:2},{t:"의도적으로 다른 접근으로 여러 번 물어보고 비교한다",s:3}] },
			{ cat:"요청의 기술", text:"AI에게 '이렇게 하지 마'라고 말해본 적 있나요?", opts:[{t:"없다",s:1},{t:"결과가 마음에 안 들 때 가끔 한다",s:2},{t:"처음부터 하지 말아야 할 것들을 명시한다",s:3}] },
			{ cat:"요청의 기술", text:"AI와 대화할 때 어떤 언어를 쓰나요?", opts:[{t:"한국어만 쓴다",s:1},{t:"필요에 따라 한/영을 섞는다",s:2},{t:"작업에 따라 최적 언어를 의도적으로 선택한다",s:3}] },
			{ cat:"요청의 기술", text:"AI에게 '왜 그렇게 생각하는지' 물어본 적 있나요?", opts:[{t:"없다",s:1},{t:"가끔 한다",s:2},{t:"항상 근거를 함께 요청한다",s:3}] },
			// ── 피드백과 수정 ─────────────────────────────────────
			{ cat:"피드백과 수정", text:"AI 결과물에서 오류를 발견했을 때?", opts:[{t:"처음부터 다시 시킨다",s:1},{t:"어느 부분이 틀렸는지 말해준다",s:2},{t:"왜 틀렸는지 이유와 함께 어떻게 고쳐야 하는지를 말해준다",s:3}] },
			{ cat:"피드백과 수정", text:"AI가 내 의도와 다른 방향으로 갔을 때?", opts:[{t:"끝까지 보고 나서 다시 시킨다",s:1},{t:"중간에 멈추고 방향을 잡아준다",s:2},{t:"체크포인트를 미리 설정해둔다",s:3}] },
			{ cat:"피드백과 수정", text:"AI가 너무 일반적인 답을 줄 때?", opts:[{t:"그냥 쓴다",s:1},{t:"'더 구체적으로'라고 한다",s:2},{t:"처음부터 구체적인 컨텍스트와 제약조건을 준다",s:3}] },
			{ cat:"피드백과 수정", text:"AI에게 비교 검토를 시켜본 적 있나요?", opts:[{t:"없다",s:1},{t:"두 가지 버전을 만들어달라고 해봤다",s:2},{t:"A/B를 만들고 어떤 게 더 나은지 이유와 함께 평가하게 한다",s:3}] },
			{ cat:"피드백과 수정", text:"AI 결과물의 품질을 어떻게 판단하나요?", opts:[{t:"느낌으로 판단한다",s:1},{t:"내가 알고 있는 지식과 비교한다",s:2},{t:"평가 기준을 미리 정해두고 체크한다",s:3}] },
			{ cat:"피드백과 수정", text:"AI가 확신 있게 틀린 답을 줬을 때?", opts:[{t:"믿고 사용했다",s:1},{t:"한 번 더 물어봤다",s:2},{t:"검증하는 방법을 따로 갖고 있다",s:3}] },
			{ cat:"피드백과 수정", text:"AI와 대화 중 내가 틀렸다는 걸 알았을 때?", opts:[{t:"모른 척 넘어간다",s:1},{t:"수정해서 다시 시킨다",s:2},{t:"내가 처음에 잘못 설명한 부분을 명확히 하고 다시 시작한다",s:3}] },
			{ cat:"피드백과 수정", text:"AI가 작성한 결과물을 팀원에게 공유할 때?", opts:[{t:"그대로 공유한다",s:1},{t:"내가 검토하고 수정해서 공유한다",s:2},{t:"AI가 썼다는 걸 명시하고 공유한다",s:3}] },
			{ cat:"피드백과 수정", text:"AI에게 같은 내용을 다른 스타일로 써달라고 해봤나요?", opts:[{t:"없다",s:1},{t:"한두 번 해봤다",s:2},{t:"목적에 따라 스타일을 지정하고 비교한다",s:3}] },
			{ cat:"피드백과 수정", text:"AI 결과물을 개선하는 나만의 프로세스가 있나요?", opts:[{t:"없다",s:1},{t:"경험적으로 대략 안다",s:2},{t:"단계별 검토 루틴이 있다",s:3}] },
			// ── 반복과 자동화 ─────────────────────────────────────
			{ cat:"반복과 자동화", text:"매주 반복되는 업무가 있다면?", opts:[{t:"매번 처음부터 한다",s:1},{t:"지난번 것을 참고해서 한다",s:2},{t:"자동화하거나 스킬로 만들었다",s:3}] },
			{ cat:"반복과 자동화", text:"프롬프트를 저장하고 관리하나요?", opts:[{t:"아니다",s:1},{t:"잘된 프롬프트를 메모해둔다",s:2},{t:"체계적으로 분류해서 관리한다",s:3}] },
			{ cat:"반복과 자동화", text:"데이터 수집이 필요한 업무에서?", opts:[{t:"직접 수집한다",s:1},{t:"AI에게 수집 방법을 물어본다",s:2},{t:"AI가 자동으로 수집하는 구조를 만들었다",s:3}] },
			{ cat:"반복과 자동화", text:"이메일 작성에 AI를 어떻게 활용하나요?", opts:[{t:"가끔 초안을 부탁한다",s:1},{t:"상황에 따른 템플릿을 만들어뒀다",s:2},{t:"수신자 파악부터 초안까지 반자동화했다",s:3}] },
			{ cat:"반복과 자동화", text:"회의 후 액션 아이템 정리를?", opts:[{t:"직접 한다",s:1},{t:"AI에게 회의록을 주고 정리를 부탁한다",s:2},{t:"자동으로 수집-정리-공유되는 구조가 있다",s:3}] },
			{ cat:"반복과 자동화", text:"정보 검색에 AI를 어떻게 활용하나요?", opts:[{t:"구글 대신 AI에게 물어본다",s:1},{t:"AI 답변을 검색으로 검증한다",s:2},{t:"특정 소스에서 자동으로 정보를 수집하는 구조가 있다",s:3}] },
			{ cat:"반복과 자동화", text:"일정 관리에 AI를 활용하나요?", opts:[{t:"활용 안 한다",s:1},{t:"일정 요약이나 우선순위 조언을 받는다",s:2},{t:"캘린더 등과 연동된 자동화가 있다",s:3}] },
			{ cat:"반복과 자동화", text:"보고서 작성에 AI를 어떻게 활용하나요?", opts:[{t:"초안을 부탁한다",s:1},{t:"데이터 수집과 초안 작성을 맡긴다",s:2},{t:"데이터 수집부터 작성, 공유까지 자동화되어 있다",s:3}] },
			{ cat:"반복과 자동화", text:"같은 작업을 팀원과 나눌 때 AI를 어떻게 활용하나요?", opts:[{t:"개인적으로만 쓴다",s:1},{t:"잘된 프롬프트를 팀과 공유한다",s:2},{t:"팀 공통 스킬이나 워크플로우를 만들었다",s:3}] },
			{ cat:"반복과 자동화", text:"반복 작업의 효율화를 측정하나요?", opts:[{t:"아니다",s:1},{t:"체감으로 효과를 판단한다",s:2},{t:"시간 절감, 품질 향상 등을 정량으로 측정한다",s:3}] },
			// ── 경계와 권한 ──────────────────────────────────────
			{ cat:"경계와 권한", text:"AI에게 어디까지 권한을 주나요?", opts:[{t:"생각해본 적 없다",s:1},{t:"민감한 정보는 주지 않는다",s:2},{t:"작업 단계별로 권한 범위를 명시해뒀다",s:3}] },
			{ cat:"경계와 권한", text:"외부에 발송되는 메시지를 AI가 작성하면?", opts:[{t:"그대로 보낸다",s:1},{t:"내가 확인하고 보낸다",s:2},{t:"처음부터 '발송은 반드시 내가 한다'는 규칙을 정해뒀다",s:3}] },
			{ cat:"경계와 권한", text:"파일이나 데이터 삭제 관련해서?", opts:[{t:"AI에게 맡긴다",s:1},{t:"중요한 것은 직접 한다",s:2},{t:"삭제 권한 자체를 주지 않는다",s:3}] },
